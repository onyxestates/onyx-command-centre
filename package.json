{
  "name": "onyx-command-centre",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "seed:demo": "tsx scripts/seed-demo-data.ts",
    "emulators": "firebase emulators:start",
    "emulators:export": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "playwright:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:rules": "firebase emulators:exec --project onyx-rules-pilot --only firestore,storage \"node --import tsx --test tests/firestore.rules.test.ts tests/storage.rules.test.ts\"",
    "verify:pilot": "corepack pnpm typecheck && corepack pnpm lint && corepack pnpm build && corepack pnpm test:rules",
    "verify:full": "corepack pnpm typecheck && corepack pnpm lint && corepack pnpm build && corepack pnpm test:rules && corepack pnpm test:e2e",
    "env:check:staging": "node scripts/check-env.mjs staging",
    "env:check:production": "node scripts/check-env.mjs production",
    "vercel:pull:staging": "bash scripts/vercel-pull-staging.sh",
    "deploy:staging": "bash scripts/vercel-deploy-staging.sh",
    "deploy:production": "bash scripts/vercel-deploy-production.sh"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.53.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.511.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^20.17.50",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.6",
    "firebase-tools": "^15.18.0",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.22.1",
    "typescript": "^5.8.3",
    "vercel": "^54.1.0"
  }
}
